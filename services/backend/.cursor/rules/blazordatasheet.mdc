/* Excel风格表格样式 */
.datasheet-container {
    border: 1px solid #c0c0c0;
    border-radius: 0;
    overflow: hidden;
    height: 500px;
    background-color: #ffffff;
    box-shadow: none;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
}

