<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.CashPaymentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="734"
             d:DesignWidth="1280">
    <Grid Background="{DynamicResource PosScreenBackgroundBrush}" Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="560" MinWidth="0" />
            <ColumnDefinition Width="480" MinWidth="0" />
            <ColumnDefinition Width="*" MinWidth="0" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="{Binding ScreenTitleText}" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="{Binding OrderSummaryText}" Foreground="{DynamicResource PosMutedForegroundBrush}" Margin="0,6,0,0" />
            </StackPanel>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding CartLines}"
                      IsReadOnly="True"
                      Style="{DynamicResource PosCartDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{loc:Loc Item}" Binding="{Binding DisplayName}" Width="*" />
                    <DataGridTextColumn Header="{loc:Loc Quantity}" Binding="{Binding Quantity, StringFormat={}{0:0.##}}" Width="76" />
                    <DataGridTextColumn Header="{loc:Loc Total}" Binding="{Binding ActualAmount, StringFormat={}{0:C2}}" Width="116" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="2" Style="{DynamicResource PosCardStyle}" Padding="18" Margin="0,14,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{loc:Loc Subtotal}" Foreground="{DynamicResource PosMutedForegroundBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:C2}}" />
                    <TextBlock Grid.Row="1" Text="{loc:Loc Discount}" Foreground="{DynamicResource PosMutedForegroundBrush}" Margin="0,8,0,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DiscountAmount, StringFormat={}{0:C2}}" Margin="0,8,0,0" />
                    <TextBlock Grid.Row="2" Text="{loc:Loc AmountDue}" FontSize="20" FontWeight="SemiBold" Margin="0,14,0,0" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ActualAmount, StringFormat={}{0:C2}}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource PosPrimaryBrush}" Margin="0,10,0,0" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{DynamicResource PosCardStyle}" Padding="16" Margin="0,0,8,0" Background="#FFFFF1D6">
                    <StackPanel>
                        <TextBlock Text="{Binding AmountTenderedTextLabel}" Foreground="#8A4B00" FontSize="11" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding AmountTenderedText, StringFormat={}{0:C2}}" FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{DynamicResource PosCardStyle}" Padding="16" Margin="8,0,0,0" Background="#FFFFE2D6">
                    <StackPanel>
                        <TextBlock Text="{Binding ChangeDueText}" Foreground="#8A2D00" FontSize="11" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ChangeDue, StringFormat={}{0:C2}}" FontSize="28" FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </Grid>

            <ItemsControl Grid.Row="1" ItemsSource="{Binding QuickCashAmounts}" Margin="0,14,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding StringFormat={}{0:C0}}"
                                Command="{Binding DataContext.QuickCashCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Style="{DynamicResource PosSecondaryButtonStyle}"
                                Margin="4"
                                Height="42" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <UniformGrid Grid.Row="2" Columns="3" Height="340" Margin="0,14,0,0" VerticalAlignment="Top">
                <Button Content="1" Command="{Binding NumberInputCommand}" CommandParameter="1" Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="2" Command="{Binding NumberInputCommand}" CommandParameter="2" Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="3" Command="{Binding NumberInputCommand}" CommandParameter="3" Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="4" Command="{Binding NumberInputCommand}" CommandParameter="4" Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="5" Command="{Binding NumberInputCommand}" CommandParameter="5" Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="6" Command="{Binding NumberInputCommand}" CommandParameter="6" Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="7" Command="{Binding NumberInputCommand}" CommandParameter="7" Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="8" Command="{Binding NumberInputCommand}" CommandParameter="8" Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="9" Command="{Binding NumberInputCommand}" CommandParameter="9" Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="." Command="{Binding NumberInputCommand}" CommandParameter="." Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="0" Command="{Binding NumberInputCommand}" CommandParameter="0" Style="{DynamicResource PosNumberButtonStyle}" />
                <Button Content="{loc:Loc Clear}" Command="{Binding NumberInputCommand}" CommandParameter="Clear" Style="{DynamicResource PosNumberButtonStyle}" Background="#FFFFDAD6" />
                <Button Content="{loc:Loc Backspace}" Command="{Binding NumberInputCommand}" CommandParameter="Back" Style="{DynamicResource PosNumberButtonStyle}" />
            </UniformGrid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="{Binding CancelText}"
                        Command="{Binding CancelCommand}"
                        Width="118"
                        Height="50"
                        Margin="0,0,10,0"
                        Style="{DynamicResource PosSecondaryButtonStyle}" />
                <Button Content="{Binding ConfirmPaymentText}"
                        Command="{Binding ConfirmPaymentCommand}"
                        Width="184"
                        Height="50"
                        Style="{DynamicResource PosPrimaryButtonStyle}" />
            </StackPanel>
        </Grid>

        <Border Grid.Column="2" Style="{DynamicResource PosCardStyle}" Padding="18">
            <StackPanel>
                <TextBlock Text="{Binding PaymentMethodText}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,14" />
                <Button Style="{DynamicResource PosPaymentMethodButtonStyle}" Background="{StaticResource PosAccentBrush}" Foreground="White">
                    <TextBlock Text="{loc:Loc payment.method.cash}" Foreground="White" FontWeight="SemiBold" />
                </Button>
                <Button Style="{DynamicResource PosPaymentMethodButtonStyle}" IsEnabled="False">
                    <TextBlock Text="{loc:Loc payment.method.card}" />
                </Button>
                <Button Style="{DynamicResource PosPaymentMethodButtonStyle}" IsEnabled="False">
                    <TextBlock Text="{loc:Loc payment.method.account}" />
                </Button>
                <Button Style="{DynamicResource PosPaymentMethodButtonStyle}" IsEnabled="False">
                    <TextBlock Text="{loc:Loc payment.method.installment}" />
                </Button>
                <Border Style="{DynamicResource PosWarningPillStyle}" Margin="0,16,0,0">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Foreground="#8A4B00" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
