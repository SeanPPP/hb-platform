<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.TransactionHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="734"
             d:DesignWidth="1280">
    <Grid Background="{DynamicResource PosScreenBackgroundBrush}" Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1020" MinWidth="0" />
            <ColumnDefinition Width="*" MinWidth="0" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel>
                <TextBlock Text="{loc:Loc TransactionHistory}" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Content="{loc:Loc history.exportCsv}"
                        DockPanel.Dock="Right"
                        Width="118"
                        Height="36"
                        Style="{StaticResource PosPrimaryButtonStyle}"
                        IsEnabled="False" />
                <Button Content="{loc:Loc history.advancedFilters}"
                        DockPanel.Dock="Right"
                        Width="148"
                        Height="36"
                        Margin="0,0,10,0"
                        Style="{StaticResource PosSecondaryButtonStyle}"
                        IsEnabled="False" />
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,18,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="1.4*" />
                </Grid.ColumnDefinitions>
                <TextBox Text="{loc:Loc history.dateRange}" IsReadOnly="True" Height="38" Style="{StaticResource PosSearchTextBoxStyle}" />
                <TextBox Grid.Column="1" Text="{loc:Loc history.allStores}" IsReadOnly="True" Height="38" Margin="10,0,0,0" Style="{StaticResource PosSearchTextBoxStyle}" />
                <TextBox Grid.Column="2" Text="{loc:Loc history.allTerminals}" IsReadOnly="True" Height="38" Margin="10,0,0,0" Style="{StaticResource PosSearchTextBoxStyle}" />
                <TextBox Grid.Column="3" Text="{loc:Loc history.search}" Height="38" Margin="10,0,0,0" Style="{StaticResource PosSearchTextBoxStyle}" />
            </Grid>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Orders}"
                      SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                      IsReadOnly="True"
                      RowHeight="54"
                      GridLinesVisibility="None"
                      Style="{DynamicResource PosCartDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding ShortOrderId}" Width="92" />
                    <DataGridTextColumn Header="{loc:Loc Store}" Binding="{Binding StoreCode}" Width="90" />
                    <DataGridTextColumn Header="{loc:Loc Terminal}" Binding="{Binding DeviceCode}" Width="104" />
                    <DataGridTextColumn Header="{loc:Loc Time}" Binding="{Binding SoldAtDisplay}" Width="150" />
                    <DataGridTextColumn Header="{loc:Loc Items}" Binding="{Binding LineCount}" Width="70" />
                    <DataGridTextColumn Header="{loc:Loc Amount}" Binding="{Binding ActualAmount, StringFormat={}{0:C2}}" Width="100" />
                    <DataGridTextColumn Header="{loc:Loc Payment}" Binding="{Binding PaymentSummary}" Width="100" />
                    <DataGridTextColumn Header="{loc:Loc common.status}" Binding="{Binding StatusLabel}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <DockPanel Grid.Row="3" Margin="0,14,0,0">
                <TextBlock Foreground="{DynamicResource PosMutedForegroundBrush}" VerticalAlignment="Center">
                    <Run Text="{loc:Loc history.showingPrefix}" />
                    <Run Text="{Binding Orders.Count, Mode=OneWay}" />
                    <Run Text=" " />
                    <Run Text="{loc:Loc history.transactions}" />
                </TextBlock>
                <Button Content="{loc:Loc common.load}"
                        Command="{Binding LoadCommand}"
                        DockPanel.Dock="Right"
                        Width="84"
                        Height="34"
                        Style="{StaticResource PosSecondaryButtonStyle}" />
            </DockPanel>
        </Grid>

        <Border Grid.Column="1"
                Background="White"
                Padding="20"
                CornerRadius="4"
                BorderBrush="{StaticResource PosBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{loc:Loc success.receiptPreview}" FontSize="16" FontWeight="SemiBold" />

                <StackPanel Grid.Row="1" Margin="0,20,0,18" HorizontalAlignment="Center">
                    <TextBlock Text="{loc:Loc AppName}" Foreground="{StaticResource PosPrimaryDarkBrush}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding PreviewOrderId}" Foreground="{DynamicResource PosMutedForegroundBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding PreviewSoldAt}" Foreground="{DynamicResource PosMutedForegroundBrush}" HorizontalAlignment="Center" />
                </StackPanel>

                <ItemsControl Grid.Row="2" ItemsSource="{Binding ReceiptLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LookupCode}" Foreground="{DynamicResource PosMutedForegroundBrush}" FontSize="11" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding ActualAmount, StringFormat={}{0:C2}}" FontWeight="SemiBold" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Row="3">
                    <Border Height="1" Background="{StaticResource PosBorderBrush}" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,7">
                        <TextBlock Text="{loc:Loc Subtotal}" Foreground="{DynamicResource PosMutedForegroundBrush}" />
                        <TextBlock Text="{Binding PreviewSubtotal, StringFormat={}{0:C2}}" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,7">
                        <TextBlock Text="{loc:Loc Discount}" Foreground="{DynamicResource PosMutedForegroundBrush}" />
                        <TextBlock Text="{Binding PreviewDiscount, StringFormat={}{0:C2}}" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid>
                        <TextBlock Text="{loc:Loc Total}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding PreviewTotal, StringFormat={}{0:C2}}" HorizontalAlignment="Right" Foreground="{StaticResource PosPrimaryDarkBrush}" FontWeight="Bold" FontSize="18" />
                    </Grid>
                </StackPanel>

                <Grid Grid.Row="4" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Content="{loc:Loc history.reprint}" Command="{Binding ReprintCommand}" Style="{StaticResource PosPrimaryButtonStyle}" />
                    <Button Grid.Column="1" Content="{loc:Loc history.refund}" Command="{Binding RefundCommand}" Margin="10,0,0,0" Style="{StaticResource PosDangerButtonStyle}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
