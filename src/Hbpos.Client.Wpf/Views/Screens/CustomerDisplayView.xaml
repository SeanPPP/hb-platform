<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.CustomerDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="734"
             d:DesignWidth="1280">
    <Grid Background="{DynamicResource PosScreenBackgroundBrush}" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="132" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="860" MinWidth="0" />
                <ColumnDefinition Width="*" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="4" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{loc:Loc ItemDescription}" Foreground="{DynamicResource PosMutedForegroundBrush}" FontSize="12" />
                        <TextBlock Grid.Column="1" Text="{loc:Loc Quantity}" Foreground="{DynamicResource PosMutedForegroundBrush}" FontSize="12" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{loc:Loc Price}" Foreground="{DynamicResource PosMutedForegroundBrush}" FontSize="12" HorizontalAlignment="Right" />
                        <TextBlock Grid.Column="3" Text="{loc:Loc Total}" Foreground="{DynamicResource PosMutedForegroundBrush}" FontSize="12" HorizontalAlignment="Right" />
                    </Grid>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Lines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" Margin="0,0,0,8" BorderBrush="#FFE4E7EC" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding LookupCode}" Foreground="{DynamicResource PosMutedForegroundBrush}" FontSize="12" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding QuantityDisplay}" Foreground="{StaticResource PosPrimaryDarkBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding UnitPrice, StringFormat={}{0:C2}}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding ActualAmount, StringFormat={}{0:C2}}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="SemiBold" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="18,0,0,0" CornerRadius="4" Background="#243B2E" ClipToBounds="True">
                <Grid>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#315C3D" Offset="0" />
                                <GradientStop Color="#D6452E" Offset="1" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle Opacity="0.25" Fill="#FF000000" />
                    <StackPanel Margin="48,44">
                        <Border Background="{StaticResource PosWarningBrush}" CornerRadius="3" Padding="8,4" HorizontalAlignment="Left">
                            <TextBlock Text="{loc:Loc customer.promotionTitle}" Foreground="#3A2400" FontSize="12" FontWeight="Bold" />
                        </Border>
                        <TextBlock Text="{loc:Loc customer.promotionSubtitle}" Margin="0,18,0,8" Foreground="White" FontSize="30" FontWeight="Bold" TextWrapping="Wrap" />
                        <TextBlock Text="{loc:Loc customer.promotionBody}" Foreground="#FFF2F4F7" FontSize="15" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Margin="0,0,36,0">
                    <TextBlock Text="{loc:Loc Subtotal}" Foreground="{DynamicResource PosMutedForegroundBrush}" FontSize="12" />
                    <TextBlock Text="{Binding Subtotal, StringFormat={}{0:C2}}" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Margin="0,0,36,0">
                    <TextBlock Text="{loc:Loc Tax}" Foreground="{DynamicResource PosMutedForegroundBrush}" FontSize="12" />
                    <TextBlock Text="{Binding TaxAmount, StringFormat={}{0:C2}}" FontSize="22" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="{loc:Loc Savings}" Foreground="{DynamicResource PosMutedForegroundBrush}" FontSize="12" />
                    <TextBlock Text="{Binding SavingsAmount, StringFormat=-{0:C2}}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource PosDangerBrush}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,28,0" VerticalAlignment="Center">
                <TextBlock Text="{loc:Loc customer.totalToPay}" Foreground="{StaticResource PosPrimaryDarkBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" />
                <TextBlock Text="{Binding TotalToPay, StringFormat={}{0:C2}}" Foreground="{StaticResource PosPrimaryBrush}" FontSize="58" FontWeight="Bold" HorizontalAlignment="Right" />
            </StackPanel>

            <Border Grid.Column="2" Background="{StaticResource PosPrimaryBrush}" CornerRadius="4" Padding="18" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{loc:Loc customer.readyForPayment}" Foreground="White" FontSize="16" FontWeight="Bold" />
                    <TextBlock Text="{loc:Loc customer.insertOrTap}" Foreground="#FFD9E7FF" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
