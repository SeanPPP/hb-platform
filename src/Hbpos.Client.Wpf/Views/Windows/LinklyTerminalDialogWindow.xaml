<Window x:Class="Hbpos.Client.Wpf.Views.Windows.LinklyTerminalDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480"
        Height="420"
        MinWidth="420"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontFamily="{StaticResource PosFontFamily}"
        Background="{StaticResource PosScreenBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="MessageTextBlock"
                   Grid.Row="0"
                   Margin="0,0,0,14"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="#B45309"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <Border Grid.Row="1"
                Padding="14"
                BorderBrush="#FFE0E4EA"
                BorderThickness="1"
                Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusLabelTextBlock"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PosMutedForegroundBrush}" />
                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="1"
                           Margin="12,0,0,0"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource PosTextBrush}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,16,0,12">
            <TextBlock x:Name="DisplayLabelTextBlock"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PosMutedForegroundBrush}" />
            <TextBlock x:Name="DisplayTextBlock"
                       Margin="0,6,0,0"
                       MinHeight="54"
                       Padding="14"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Background="White"
                       Foreground="{StaticResource PosTextBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <DockPanel Grid.Row="3" LastChildFill="True">
            <TextBlock x:Name="ReceiptLabelTextBlock"
                       DockPanel.Dock="Top"
                       Margin="0,0,0,6"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PosMutedForegroundBrush}" />
            <TextBox x:Name="ReceiptTextBox"
                     IsReadOnly="True"
                     BorderBrush="#FFE0E4EA"
                     Background="White"
                     FontFamily="Consolas"
                     FontSize="12"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" />
        </DockPanel>

        <StackPanel x:Name="ActionButtonsPanel"
                    Grid.Row="4"
                    Margin="0,18,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal" />
    </Grid>
</Window>
