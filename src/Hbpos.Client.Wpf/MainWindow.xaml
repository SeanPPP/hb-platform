<Window x:Class="Hbpos.Client.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Hbpos.Client.Wpf.Views.Screens"
        xmlns:vm="clr-namespace:Hbpos.Client.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="HB POS"
        Height="860"
        Width="1440"
        MinHeight="720"
        MinWidth="1080"
        FontFamily="{StaticResource PosFontFamily}"
        Background="{StaticResource PosScreenBackgroundBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:PosTerminalViewModel}">
            <views:PosTerminalView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CashPaymentViewModel}">
            <views:CashPaymentView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PaymentSuccessViewModel}">
            <views:PaymentSuccessView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TransactionHistoryViewModel}">
            <views:TransactionHistoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerDisplayViewModel}">
            <views:CustomerDisplayView />
        </DataTemplate>
        <Style x:Key="ShellNavButtonStyle" TargetType="Button" BasedOn="{StaticResource PosSecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource PosScreenBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PosHeaderBackgroundBrush}" BorderBrush="{StaticResource PosBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Margin="18,0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Loc AppName}"
                               Foreground="{StaticResource PosPrimaryDarkBrush}"
                               FontWeight="Bold"
                               FontSize="16"
                               VerticalAlignment="Center" />
                    <Button Content="{loc:Loc NavPos}"
                            Command="{Binding ShowPosCommand}"
                            Margin="18,0,0,0"
                            Style="{StaticResource ShellNavButtonStyle}" />
                    <Button Content="{loc:Loc CashPayment}"
                            Command="{Binding ShowCashPaymentCommand}"
                            Margin="6,0,0,0"
                            Style="{StaticResource ShellNavButtonStyle}" />
                    <Button Content="{loc:Loc Success}"
                            Command="{Binding ShowPaymentSuccessCommand}"
                            Margin="6,0,0,0"
                            Style="{StaticResource ShellNavButtonStyle}" />
                    <Button Content="{loc:Loc History}"
                            Command="{Binding ShowHistoryCommand}"
                            Margin="6,0,0,0"
                            Style="{StaticResource ShellNavButtonStyle}" />
                    <Button Content="{loc:Loc Display}"
                            Command="{Binding ShowCustomerDisplayCommand}"
                            Margin="6,0,0,0"
                            Style="{StaticResource ShellNavButtonStyle}" />
                    <TextBlock Text="|" Foreground="{StaticResource PosBorderBrush}" Margin="14,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Session.StoreName}" Foreground="{StaticResource PosMutedForegroundBrush}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13" />
                    <TextBlock Text="{Binding Session.DeviceCode}" Foreground="{StaticResource PosMutedForegroundBrush}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13" />
                    <TextBlock Text="{Binding Session.CashierName}" Foreground="{StaticResource PosMutedForegroundBrush}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13" />
                    <Border Style="{StaticResource PosStatusPillStyle}" Margin="0,0,8,0">
                        <TextBlock Text="{Binding OnlineStateText}" Foreground="{StaticResource PosSuccessBrush}" FontWeight="SemiBold" />
                    </Border>
                    <Border Style="{StaticResource PosWarningPillStyle}" Margin="0,0,12,0">
                        <TextBlock Text="{Binding PendingSyncText}" Foreground="#8A4B00" FontWeight="SemiBold" />
                    </Border>
                    <ComboBox SelectedValue="{Binding SelectedCultureName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag"
                              Width="132"
                              Height="34"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Tag="en-US" Content="{loc:Loc LanguageEnglish}" />
                        <ComboBoxItem Tag="zh-CN" Content="{loc:Loc LanguageChineseSimplified}" />
                    </ComboBox>
            </StackPanel>
        </Border>

        <ContentControl Grid.Row="1" Content="{Binding CurrentScreen}" />

        <Border Grid.Row="2" Background="{StaticResource PosFooterBackgroundBrush}" BorderBrush="{StaticResource PosBorderBrush}" BorderThickness="0,1,0,0" Padding="18,5">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource PosMutedForegroundBrush}" FontSize="12" />
        </Border>
    </Grid>
</Window>
