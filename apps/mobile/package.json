{
  "name": "hbwebexpoapp",
  "version": "1.0.2",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ota:legacy-apk-notice:preview": "EXPO_PUBLIC_APP_BUILD_PROFILE=preview EXPO_PUBLIC_NATIVE_APK_INSTALLER_ENABLED=false EXPO_PUBLIC_RUNTIME_VERSION=1.0.1 eas update --channel preview --message \"提示测试机下载安装新版 APK\"",
    "ota:legacy-apk-notice:production": "EXPO_PUBLIC_APP_BUILD_PROFILE=production EXPO_PUBLIC_NATIVE_APK_INSTALLER_ENABLED=false EXPO_PUBLIC_RUNTIME_VERSION=1.0.1 eas update --channel production --message \"提示门店下载安装新版 APK\"",
    "test:ota-config": "node scripts/check-ota-config.js",
    "test:i18n-locales": "node scripts/check-locale-parity.js",
    "test:native-app-update": "npx --yes tsx src/modules/updates/native-app-update.test.ts",
    "test:public-holiday-sync": "npx --yes tsx src/modules/attendance/public-holiday-sync.test.ts",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.100.9",
    "axios": "^1.16.0",
    "expo": "~54.0.35",
    "expo-application": "~7.0.8",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-intent-launcher": "~13.0.8",
    "expo-key-event": "^1.8.3",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.9",
    "expo-router": "~6.0.24",
    "expo-screen-orientation": "~9.0.9",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "i18next": "^26.2.0",
    "js-sha256": "^0.11.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-paper": "^5.15.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
