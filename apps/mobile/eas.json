{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_BUILD_PROFILE": "development",
        "EXPO_PUBLIC_NATIVE_APK_INSTALLER_ENABLED": "false",
        "EXPO_PUBLIC_RUNTIME_VERSION": "1.0.2"
      }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APP_BUILD_PROFILE": "preview",
        "EXPO_PUBLIC_NATIVE_APK_INSTALLER_ENABLED": "true",
        "EXPO_PUBLIC_RUNTIME_VERSION": "1.0.2"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APP_BUILD_PROFILE": "production",
        "EXPO_PUBLIC_NATIVE_APK_INSTALLER_ENABLED": "true",
        "EXPO_PUBLIC_RUNTIME_VERSION": "1.0.2"
      },
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6786073002"
      }
    }
  }
}
