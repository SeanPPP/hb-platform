{
  "expo": {
    "name": "HB",
    "slug": "hbweb-expo",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hbwebexpo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": "1.0.2",
    "updates": {
      "url": "https://u.expo.dev/3b37541e-6191-460d-9a57-fe6691e206cf"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FBFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hbweb.expo",
      "appleTeamId": "3SV4A23SVW",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for scanning barcodes and taking profile photos",
        "NSBluetoothAlwaysUsageDescription": "Used to scan and connect Bluetooth receipt and label printers",
        "NSBluetoothPeripheralUsageDescription": "Used to scan and connect Bluetooth receipt and label printers",
        "NSMicrophoneUsageDescription": "Used for audio feedback",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hbweb.expo",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.REQUEST_INSTALL_PACKAGES"
      ]
    },
    "plugins": [
      "expo-router",
      "./plugins/with-ios-printer-module",
      [
        "expo-camera",
        {
          "cameraPermission": "Used for scanning barcodes and taking profile photos"
        }
      ],
      "expo-audio",
      "expo-localization",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-logo.png",
          "backgroundColor": "#F8FBFF",
          "imageWidth": 210,
          "resizeMode": "contain"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3b37541e-6191-460d-9a57-fe6691e206cf"
      }
    }
  }
}
