{
  "CentralLogging": {
    "Enabled": false,
    "ProjectCode": "hbpos_api",
    "Environment": "Production",
    "SourceType": "Backend",
    "ServiceName": "Hbpos.Api",
    "MinimumLevel": "Warning",
    "QueueCapacity": 1000,
    "BatchSize": 100,
    "HttpTimeoutSeconds": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileLogging": {
    "Enabled": true,
    "Path": "logs/hbpos-api.log",
    "MinimumLevel": "Information"
  },
  "LinklyCloudBackendAsync": {
    "PublicNotificationBaseUrl": ""
  },
  "LinklyCloudBackend": {},
  "AppUpdate": {
    "CenterBaseUrl": "",
    "Channel": "production",
    "CheckApiKey": "",
    "CenterApiKey": ""
  },
  "CashierAuthorization": {
    "Mode": "Audit"
  },
  "DataProtection": {
    "ApplicationName": "Hbpos.Api",
    "KeysPath": "App_Data/DataProtectionKeys"
  },
  "AllowedHosts": "*"
}
