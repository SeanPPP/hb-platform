<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.TransactionHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosSurfaceAltBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="HistoryFilterLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource PosMutedForegroundBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="0" />
            <ColumnDefinition Width="380" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PosScreenBackgroundBrush}" Padding="24,20">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="1.05*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding ReturnToPosCommand}"
                                Height="38"
                                MinWidth="0"
                                Padding="10,0"
                                Margin="0,0,12,0"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource PosSecondaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16" Margin="0,0,6,0" />
                                <TextBlock Text="{loc:Loc shell.backToPos}" />
                            </StackPanel>
                        </Button>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="{loc:Loc Source}" Style="{StaticResource HistoryFilterLabel}" />
                            <Border Height="52"
                                    Padding="14,0"
                                    BorderBrush="{StaticResource PosBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Background="White">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <RadioButton Content="{loc:Loc history.source.local}"
                                                 GroupName="HistorySource"
                                                 IsChecked="{Binding IsLocalSourceSelected, Mode=TwoWay}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,20,0" />
                                    <RadioButton Content="{loc:Loc history.source.online}"
                                                 GroupName="HistorySource"
                                                 IsChecked="{Binding IsOnlineSourceSelected, Mode=TwoWay}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,20,0" />
                                    <RadioButton Content="{loc:Loc history.source.installments}"
                                                 GroupName="HistorySource"
                                                 IsChecked="{Binding IsInstallmentSourceSelected, Mode=TwoWay}"
                                                 VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock Text="{loc:Loc history.dateRangeLabel}" Style="{StaticResource HistoryFilterLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Height="52"
                                            FontSize="16" />
                                <DatePicker Grid.Column="2"
                                            SelectedDate="{Binding DateTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Height="52"
                                            FontSize="16" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="{loc:Loc Terminal}" Style="{StaticResource HistoryFilterLabel}" />
                            <ComboBox ItemsSource="{Binding TerminalOptions}"
                                      SelectedItem="{Binding SelectedTerminalOption, Mode=TwoWay}"
                                      DisplayMemberPath="Label"
                                      Height="52"
                                      FontSize="16" />
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="{loc:Loc history.searchLabel}" Style="{StaticResource HistoryFilterLabel}" />
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="{Binding SearchHintText}"
                                     Height="52"
                                     FontSize="16"
                                     Style="{StaticResource PosSearchTextBoxStyle}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Command="{Binding LoadCommand}"
                                MinWidth="116"
                                Height="52"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource PosPrimaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Sync" Width="16" Height="16" Foreground="White" Margin="0,0,6,0" />
                                <TextBlock Text="{loc:Loc common.load}" Foreground="White" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="12" Margin="24,0,24,0" ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" />
                </Border.Effect>
                <DataGrid x:Name="HistoryOrdersGrid"
                          ItemsSource="{Binding Orders}"
                          SelectedItem="{Binding SelectedOrder, Mode=TwoWay}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowBackground="White"
                          AlternatingRowBackground="#FFFAFBFF"
                          RowHeight="60"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          Style="{StaticResource PosCartDataGridStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding DisplayOrderId}" Width="134" />
                        <DataGridTextColumn Header="{loc:Loc Store}" Binding="{Binding StoreCode}" Width="92" />
                        <DataGridTextColumn Header="{loc:Loc Terminal}" Binding="{Binding DeviceCode}" Width="106" />
                        <DataGridTextColumn x:Name="StandardCashierColumn" Header="{loc:Loc Cashier}" Binding="{Binding CashierName}" Width="116" />
                        <DataGridTextColumn x:Name="InstallmentCustomerColumn" Header="{loc:Loc Customer}" Binding="{Binding CashierName}" Width="116" Visibility="Collapsed" />
                        <DataGridTextColumn x:Name="InstallmentPhoneColumn" Header="{loc:Loc Phone}" Binding="{Binding CustomerPhone}" Width="118" Visibility="Collapsed" />
                        <DataGridTextColumn Header="{loc:Loc Time}" Binding="{Binding SoldAtDisplay}" Width="154" />
                        <DataGridTextColumn x:Name="StandardItemsColumn" Header="{loc:Loc Items}" Binding="{Binding LineCount}" Width="72" />
                        <DataGridTextColumn x:Name="InstallmentTotalColumn" Header="{loc:Loc Total}" Binding="{Binding TotalAmount, StringFormat={}{0:C2}}" Width="104" Visibility="Collapsed" />
                        <DataGridTextColumn x:Name="StandardAmountColumn" Header="{loc:Loc Amount}" Binding="{Binding ActualAmount, StringFormat={}{0:C2}}" Width="112" />
                        <DataGridTextColumn x:Name="InstallmentOutstandingColumn" Header="{loc:Loc payment.installment.outstanding}" Binding="{Binding ActualAmount, StringFormat={}{0:C2}}" Width="112" Visibility="Collapsed" />
                        <DataGridTextColumn x:Name="StandardPaymentColumn" Header="{loc:Loc Payment}" Binding="{Binding PaymentSummary}" Width="108" />
                        <DataGridTextColumn x:Name="InstallmentPaidColumn" Header="{loc:Loc history.installment.paid}" Binding="{Binding PaymentSummary}" Width="108" Visibility="Collapsed" />
                        <DataGridTextColumn Header="{loc:Loc common.status}" Binding="{Binding StatusLabel}" Width="*" />
                        <DataGridTemplateColumn Header="{loc:Loc suspended.recall}" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RecallOrderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding CanRecall}"
                                            Visibility="{Binding CanRecall, Converter={StaticResource BoolToVis}}"
                                            Height="34"
                                            Padding="10,0"
                                            Style="{StaticResource PosSecondaryButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ClipboardTextClock" Width="14" Height="14" Margin="0,0,4,0" />
                                            <TextBlock Text="{loc:Loc suspended.recall}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="{loc:Loc history.installment.continuePayment}" Width="124">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.ContinueInstallmentPaymentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding CanContinueInstallmentPayment}"
                                            Visibility="{Binding CanContinueInstallmentPayment, Converter={StaticResource BoolToVis}}"
                                            Height="34"
                                            Padding="10,0"
                                            Style="{StaticResource PosPrimaryButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="CalendarClock" Width="14" Height="14" Foreground="White" Margin="0,0,4,0" />
                                            <TextBlock Text="{loc:Loc history.installment.continuePayment}" Foreground="White" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <DockPanel Grid.Row="2" Margin="24,14,24,18">
                <TextBlock Foreground="{StaticResource PosMutedForegroundBrush}" VerticalAlignment="Center">
                    <Run Text="{loc:Loc history.showingPrefix}" />
                    <Run Text="{Binding Orders.Count, Mode=OneWay}" />
                    <Run Text=" " />
                    <Run Text="{loc:Loc history.transactions}" />
                </TextBlock>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource PosDangerBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Grid>

        <Border Grid.Column="1" Background="#FFE7E8EB" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="2,2,0,0" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <materialDesign:PackIcon Kind="Receipt" Width="18" Height="18" Foreground="{StaticResource PosPrimaryBrush}" Margin="0,0,6,0" />
                                <TextBlock Text="{loc:Loc success.receiptPreview}" FontSize="14" FontWeight="Black" Foreground="{StaticResource PosTextBrush}" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding ReceiptPreviewRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}"
                                                   Margin="0,0,0,3"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment" Value="Left" />
                                                    <Setter Property="FontWeight" Value="Normal" />
                                                    <Setter Property="Foreground" Value="{StaticResource PosTextBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCentered}" Value="True">
                                                            <Setter Property="TextAlignment" Value="Center" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsRightAligned}" Value="True">
                                                            <Setter Property="TextAlignment" Value="Right" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEmphasized}" Value="True">
                                                            <Setter Property="FontWeight" Value="Black" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsMachineCode}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource PosPrimaryBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Row="1" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.ColumnSpan="2"
                            Command="{Binding ReprintCommand}"
                            Height="56"
                            Visibility="{Binding IsReprintVisible, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource PosPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Printer" Width="16" Height="16" Foreground="White" Margin="0,0,6,0" />
                            <TextBlock Text="{loc:Loc history.reprint}" Foreground="White" />
                        </StackPanel>
                    </Button>
                    <Button Grid.ColumnSpan="2"
                            Command="{Binding RecallSelectedCommand}"
                            Height="56"
                            Visibility="{Binding IsRecallVisible, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource PosPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClipboardTextClock" Width="16" Height="16" Foreground="White" Margin="0,0,6,0" />
                            <TextBlock Text="{loc:Loc suspended.recall}" Foreground="White" />
                        </StackPanel>
                    </Button>
                    <Button Grid.ColumnSpan="2"
                            Command="{Binding ContinueInstallmentPaymentCommand}"
                            CommandParameter="{Binding SelectedOrder}"
                            Height="56"
                            Visibility="{Binding IsContinueInstallmentPaymentVisible, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource PosPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CalendarClock" Width="16" Height="16" Foreground="White" Margin="0,0,6,0" />
                            <TextBlock Text="{loc:Loc history.installment.continuePayment}" Foreground="White" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
