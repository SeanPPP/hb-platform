<UserControl x:Class="Hbpos.Client.Wpf.Views.Screens.ReceiptReturnsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="clr-namespace:Hbpos.Client.Wpf.Services"
             mc:Ignorable="d"
             d:DesignHeight="688"
             d:DesignWidth="1366"
             Background="{StaticResource PosScreenBackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ReturnPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PosSurfaceBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ReturnHeaderLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="{StaticResource PosMutedForegroundBrush}" />
        </Style>

        <Style x:Key="ReturnDangerAmountStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PosDangerBrush}" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>

        <!-- 退货表格操作按钮固定尺寸，避免全局按钮内边距在窄列中挤压图标。 -->
        <Style x:Key="ReturnTableActionCellStyle" TargetType="DataGridCell">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ReturnTablePrimaryIconButtonStyle" TargetType="Button" BasedOn="{StaticResource PosPrimaryButtonStyle}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ReturnTableDangerIconButtonStyle" TargetType="Button" BasedOn="{StaticResource ReturnTablePrimaryIconButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PosDangerBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PosDangerBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,18,24,14" Background="{StaticResource PosSurfaceAltBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource PosSecondaryButtonStyle}"
                        Margin="0,0,16,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="18" Height="18" Margin="0,0,8,0" />
                        <TextBlock Text="{loc:Loc shell.backToPos}" />
                    </StackPanel>
                </Button>

                <TextBlock Grid.Column="1"
                           Text="{Binding OrderSummaryText}"
                           Foreground="{StaticResource PosMutedForegroundBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox IsChecked="{Binding IsNoReceiptMode}"
                              Content="{loc:Loc returns.noReceipt}"
                              VerticalAlignment="Center"
                              FontWeight="Bold"
                              Margin="0,0,0,0" />
                    <Button Command="{Binding OpenNoReceiptOpenItemDialogCommand}"
                            Visibility="{Binding IsNoReceiptMode, Converter={StaticResource BoolToVis}}"
                            Style="{StaticResource PosSecondaryButtonStyle}"
                            Height="38"
                            MinWidth="150"
                            Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="PlusCircle" Width="17" Height="17" Margin="0,0,8,0" />
                            <TextBlock Text="{loc:Loc returns.addOpenItem}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,18,24,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Height="58" Background="#FFE2E2E6" CornerRadius="14" Padding="14,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Kind="BarcodeScan"
                                             Width="24"
                                             Height="24"
                                             Foreground="{StaticResource PosPrimaryBrush}"
                                             VerticalAlignment="Center" />
                    <!-- 条码/订单号扫码框关闭中文输入法，避免扫码时弹出候选窗。 -->
                    <TextBox Grid.Column="1"
                             Text="{Binding ScanText, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="{loc:Loc returns.searchHint}"
                             InputMethod.IsInputMethodEnabled="False"
                             InputMethod.PreferredImeState="Off"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="18"
                             FontWeight="Bold"
                             VerticalContentAlignment="Center"
                             Padding="12,0">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LookupCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="2"
                            Command="{Binding LookupCommand}"
                            Height="42"
                            MinWidth="128"
                            Style="{StaticResource PosPrimaryButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Foreground="White" Margin="0,0,8,0" />
                            <TextBlock Text="{loc:Loc Search}" Foreground="White" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ReturnPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#FFF3F3F7" Padding="18,14" CornerRadius="12,12,0,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Background="#FFE2E2E6" CornerRadius="8" Padding="10,4">
                                    <TextBlock FontSize="11" FontWeight="Black" Foreground="{StaticResource PosMutedForegroundBrush}">
                                        <Run Text="{Binding OrderLines.Count, Mode=OneWay}" />
                                        <Run Text=" " />
                                        <Run Text="{loc:Loc Items}" />
                                    </TextBlock>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc returns.originalReceipt}" FontSize="17" FontWeight="Black" />
                                    <TextBlock Text="{loc:Loc returns.staleWarning}"
                                               Visibility="{Binding ReturnRecordsMayBeStale, Converter={StaticResource BoolToVis}}"
                                               FontSize="11"
                                               Foreground="#FF8F4E00"
                                               FontWeight="Bold"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding OrderLines}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowHeight="58"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Style="{StaticResource PosCartDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc Item}" Binding="{Binding DisplayName}" Width="*" />
                                <DataGridTextColumn Header="{loc:Loc Barcode}" Binding="{Binding LookupCode}" Width="112" />
                                <DataGridTextColumn Header="{loc:Loc returns.available}" Binding="{Binding AvailableRemaining, StringFormat={}{0:0.##}}" Width="84" />
                                <DataGridTextColumn Header="{loc:Loc UnitPrice}" Binding="{Binding ReturnUnitAmount, StringFormat={}{0:C2}}" Width="96" />
                                <DataGridTemplateColumn Header="" Width="64" CellStyle="{StaticResource ReturnTableActionCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.AddReceiptLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource ReturnTablePrimaryIconButtonStyle}">
                                                <materialDesign:PackIcon Kind="ArrowRight" Width="18" Height="18" Foreground="White" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource ReturnPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#FFFFDAD6" Padding="18,14" CornerRadius="12,12,0,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Background="White" CornerRadius="8" Padding="10,4">
                                    <TextBlock FontSize="11" FontWeight="Black">
                                        <Run Text="{Binding PendingSkuCount, Mode=OneWay}" />
                                        <Run Text=" " />
                                        <Run Text="{loc:Loc Items}" />
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="{loc:Loc returns.pending}" FontSize="17" FontWeight="Black" Foreground="{StaticResource PosDangerBrush}" />
                            </DockPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding PendingLines}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  RowHeight="58"
                                  GridLinesVisibility="None"
                                  BorderThickness="0"
                                  Style="{StaticResource PosCartDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{loc:Loc Item}" Binding="{Binding DisplayName}" Width="*" />
                                <DataGridTextColumn Header="{loc:Loc Quantity}" Binding="{Binding Quantity, StringFormat={}{0:0.##}}" Width="82" />
                                <DataGridTextColumn Header="{loc:Loc LineTotal}" Binding="{Binding NegativeSubtotal, StringFormat={}{0:C2}}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ReturnDangerAmountStyle}" />
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="" Width="64" CellStyle="{StaticResource ReturnTableActionCellStyle}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.RemovePendingLineCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"
                                                    services:ButtonFeedback.Cue="Delete"
                                                    Style="{StaticResource ReturnTableDangerIconButtonStyle}">
                                                <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="White" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2" Background="#EFFFF7F7" Padding="18" CornerRadius="0,0,12,12">
                            <DockPanel>
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc returns.totalRefund}" Style="{StaticResource ReturnHeaderLabelStyle}" Foreground="{StaticResource PosDangerBrush}" />
                                    <TextBlock Text="{Binding PendingTotal, StringFormat={}{0:C2}}"
                                               FontSize="34"
                                               Style="{StaticResource ReturnDangerAmountStyle}" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding ConfirmToCartCommand}"
                                        MinWidth="180"
                                        Height="56"
                                        Style="{StaticResource PosPrimaryButtonStyle}"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Cart" Width="22" Height="22" Foreground="White" Margin="0,0,10,0" />
                                        <TextBlock Text="{loc:Loc returns.addToCart}" Foreground="White" FontSize="16" FontWeight="Black" />
                                    </StackPanel>
                                </Button>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource PosSurfaceBrush}" Padding="24,10">
            <DockPanel>
                <Button DockPanel.Dock="Right" Command="{Binding ClearCommand}" Style="{StaticResource PosSecondaryButtonStyle}" MinWidth="110">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloseCircle" Width="17" Height="17" Margin="0,0,8,0" />
                        <TextBlock Text="{loc:Loc Clear}" />
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource PosMutedForegroundBrush}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <Border Grid.RowSpan="3"
                Panel.ZIndex="20"
                Background="#66000000"
                Visibility="{Binding IsOpenItemDialogOpen, Converter={StaticResource BoolToVis}}">
            <Border Width="720"
                    Padding="24"
                    Background="{StaticResource PosSurfaceBrush}"
                    CornerRadius="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,18">
                        <TextBlock Text="{loc:Loc returns.openItem.title}"
                                   FontSize="20"
                                   FontWeight="Black" />
                        <TextBlock Text="{loc:Loc returns.openItem.subtitle}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource PosMutedForegroundBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{loc:Loc returns.openItem.name}"
                                       Style="{StaticResource ReturnHeaderLabelStyle}"
                                       Margin="0,0,0,6" />
                            <Button Command="{Binding SelectOpenItemDescriptionKeyboardCommand}"
                                    MinHeight="54"
                                    Padding="12,8"
                                    HorizontalContentAlignment="Stretch"
                                    Style="{StaticResource PosSecondaryButtonStyle}">
                                <TextBlock Text="{Binding OpenItemDisplayName}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{loc:Loc returns.openItem.price}"
                                       Style="{StaticResource ReturnHeaderLabelStyle}"
                                       Margin="0,0,0,6" />
                            <Button Command="{Binding SelectOpenItemAmountKeyboardCommand}"
                                    MinHeight="54"
                                    Padding="12,8"
                                    HorizontalContentAlignment="Right"
                                    Style="{StaticResource PosSecondaryButtonStyle}">
                                <TextBlock Text="{Binding OpenItemUnitPriceText}"
                                           FontSize="24"
                                           FontWeight="Black"
                                           Foreground="{StaticResource PosDangerBrush}" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,18">
                        <StackPanel Visibility="{Binding IsOpenItemDescriptionKeyboardVisible, Converter={StaticResource BoolToVis}}">
                            <UniformGrid Columns="10">
                                <Button Content="Q" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="Q" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="W" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="W" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="E" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="E" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="R" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="R" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="T" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="T" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="Y" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="Y" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="U" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="U" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="I" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="I" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="O" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="O" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="P" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="P" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            </UniformGrid>
                            <UniformGrid Columns="9" Margin="28,0">
                                <Button Content="A" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="A" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="S" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="S" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="D" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="D" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="F" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="F" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="G" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="G" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="H" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="H" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="J" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="J" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="K" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="K" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="L" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="L" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            </UniformGrid>
                            <UniformGrid Columns="7" Margin="72,0">
                                <Button Content="Z" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="Z" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="X" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="X" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="C" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="C" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="V" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="V" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="B" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="B" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="N" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="N" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Content="M" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="M" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            </UniformGrid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="{loc:Loc Clear}" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="Clear" Style="{StaticResource PosStitchClearNumberButtonStyle}" />
                                <Button Grid.Column="1" Content="{loc:Loc common.space}" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="Space" Style="{StaticResource PosStitchNumberButtonStyle}" />
                                <Button Grid.Column="2" Content="{loc:Loc Backspace}" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="Back" Style="{StaticResource PosStitchClearNumberButtonStyle}" />
                            </Grid>
                        </StackPanel>

                        <UniformGrid Columns="3"
                                     Width="360"
                                     HorizontalAlignment="Center"
                                     Visibility="{Binding IsOpenItemAmountKeyboardVisible, Converter={StaticResource BoolToVis}}">
                            <Button Content="1" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="1" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            <Button Content="2" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="2" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            <Button Content="3" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="3" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            <Button Content="4" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="4" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            <Button Content="5" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="5" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            <Button Content="6" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="6" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            <Button Content="7" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="7" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            <Button Content="8" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="8" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            <Button Content="9" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="9" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            <Button Content="{loc:Loc Clear}" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="Clear" Style="{StaticResource PosStitchClearNumberButtonStyle}" />
                            <Button Content="0" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="0" Style="{StaticResource PosStitchNumberButtonStyle}" />
                            <Button Content="{loc:Loc Backspace}" Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="Back" Style="{StaticResource PosStitchClearNumberButtonStyle}" />
                            <Button Content="." Command="{Binding OpenItemKeyboardInputCommand}" CommandParameter="." Style="{StaticResource PosStitchNumberButtonStyle}" />
                        </UniformGrid>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelNoReceiptOpenItemDialogCommand}"
                                Style="{StaticResource PosSecondaryButtonStyle}"
                                MinWidth="110"
                                Height="44"
                                Margin="0,0,10,0">
                            <TextBlock Text="{loc:Loc Cancel}" />
                        </Button>
                        <Button Command="{Binding ConfirmNoReceiptOpenItemCommand}"
                                Style="{StaticResource PosPrimaryButtonStyle}"
                                MinWidth="128"
                                Height="44">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" Width="18" Height="18" Foreground="White" Margin="0,0,8,0" />
                                <TextBlock Text="{loc:Loc Add}" Foreground="White" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
