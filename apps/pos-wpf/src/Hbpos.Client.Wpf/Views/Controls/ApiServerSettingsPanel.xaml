<UserControl x:Class="Hbpos.Client.Wpf.Views.Controls.ApiServerSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Hbpos.Client.Wpf.Localization"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Background="{StaticResource PosSurfaceBrush}"
            BorderBrush="#FFE0E4EC"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
        <StackPanel>
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Grid.Column="0"
                                         Kind="ServerNetwork"
                                         Width="22"
                                         Height="22"
                                         Foreground="{StaticResource PosPrimaryBrush}"
                                         Margin="0,0,10,0" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{loc:Loc settings.serverAddress.title}"
                               FontSize="16"
                               FontWeight="Black"
                               Foreground="{StaticResource PosTextBrush}" />
                    <TextBlock Text="{loc:Loc settings.serverAddress.description}"
                               FontSize="12"
                               Foreground="{StaticResource PosMutedForegroundBrush}"
                               TextWrapping="Wrap"
                               Margin="0,3,0,0" />
                </StackPanel>
            </Grid>

            <TextBlock Text="{loc:Loc settings.serverAddress.address}"
                       FontSize="12"
                       FontWeight="Bold"
                       Foreground="{StaticResource PosMutedForegroundBrush}"
                       Margin="0,0,0,6" />
            <TextBox Text="{Binding ServerAddressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="{loc:Loc settings.serverAddress.address}"
                     Style="{StaticResource PosSearchTextBoxStyle}"
                     Height="42"
                     FontSize="13"
                     Margin="0,0,0,10" />

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Command="{Binding TestConnectionCommand}"
                        AutomationProperties.Name="{loc:Loc settings.serverAddress.test}"
                        Style="{StaticResource PosSecondaryButtonStyle}"
                        Height="42">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="LanConnect" Width="18" Height="18" Margin="0,0,8,0" />
                        <TextBlock Text="{loc:Loc settings.serverAddress.test}" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2"
                        Command="{Binding SaveCommand}"
                        AutomationProperties.Name="{loc:Loc settings.serverAddress.save}"
                        Style="{StaticResource PosPrimaryButtonStyle}"
                        Height="42">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" Margin="0,0,8,0" Foreground="White" />
                        <TextBlock Text="{loc:Loc settings.serverAddress.save}" Foreground="White" />
                    </StackPanel>
                </Button>
            </Grid>

            <Border BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#FFF6F8FB" />
                        <Setter Property="BorderBrush" Value="#FFE0E4EC" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RestartRequired}" Value="True">
                                <Setter Property="Background" Value="#FFFFF7E8" />
                                <Setter Property="BorderBrush" Value="#FFFFD59B" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PosMutedForegroundBrush}"
                           TextWrapping="Wrap"
                           AutomationProperties.LiveSetting="Polite" />
            </Border>
        </StackPanel>
    </Border>
</UserControl>
